<Project>
    <ItemGroup>
        <CompilerVisibleProperty Include="EmbeddedResourceStringExtensions" />

        <CompilerVisibleItemMetadata Include="EmbeddedResource" MetadataName="MyAssemblyResource" />
        <CompilerVisibleItemMetadata Include="EmbeddedResource" MetadataName="Kind" />
        <CompilerVisibleItemMetadata Include="EmbeddedResource" MetadataName="Comment" />
        <CompilerVisibleItemMetadata Include="EmbeddedResource" MetadataName="Value" />

        <CompilerVisibleItemMetadata Include="ResxCode" MetadataName="MyAssemblyStrings" />
        <CompilerVisibleItemMetadata Include="ResxCode" MetadataName="ManifestResourceName" />
    </ItemGroup>

    <ItemDefinitionGroup>
        <EmbeddedResource>
            <Link />
            <AreaPath />
            <Area />
            <Value />
        </EmbeddedResource>
    </ItemDefinitionGroup>

    <Target Name="PrepareEmbeddedResources" DependsOnTargets="PrepareResourceNames" />

    <Target Name="_InjectStringsResxAdditionalFiles" BeforeTargets="GenerateMSBuildEditorConfigFileShouldRun" DependsOnTargets="CreateManifestResourceNames">
        <ItemGroup>
            <!-- Only primary .resx files (no culture suffix like .fr.resx) with MyAssemblyStrings=true or auto-detected -->
            <_ResxStrings
                Include="@(EmbeddedResource)"
                Condition="'%(Extension)' == '.resx' AND !$([System.String]::new('%(Filename)').Contains('.')) AND '%(ManifestResourceName)' != ''"
            />
            <_ResxStrings>
                <MyAssemblyStrings>true</MyAssemblyStrings>
            </_ResxStrings>
            <ResxCode Include="@(_ResxStrings)" />
            <AdditionalFiles Include="@(_ResxStrings)" />
        </ItemGroup>
    </Target>

    <Target Name="_InjectResourcesAdditionalFiles" BeforeTargets="GenerateMSBuildEditorConfigFileShouldRun" DependsOnTargets="PrepareEmbeddedResources">
        <ItemGroup>
            <EmbeddedResource Condition="!$([System.IO.Path]::IsPathRooted('%(RelativeDir)')) OR '%(Link)' != ''">
                <AreaPath Condition="!$([System.IO.Path]::IsPathRooted('%(RelativeDir)'))">%(RelativeDir)%(Filename)</AreaPath>
                <AreaPath Condition="'%(Link)' != ''">
                    $([System.IO.Path]::GetDirectoryName('%(Link)'))$([System.IO.Path]::DirectorySeparatorChar)$([System.IO.Path]::GetFileNameWithoutExtension('%(Link)'))
                </AreaPath>
                <FileExtension Condition="!$([System.IO.Path]::IsPathRooted('%(RelativeDir)'))">%(Extension)</FileExtension>
                <FileExtension Condition="'%(Link)' != ''">$([System.IO.Path]::GetExtension('%(Link)'))</FileExtension>
            </EmbeddedResource>
            <EmbeddedResource Condition="'%(AreaPath)' != ''">
                <Area>$([MSBuild]::ValueOrDefault('%(AreaPath)', '').Replace('\', '.').Replace('/', '.'))</Area>
                <Value>%(AreaPath)%(FileExtension)</Value>
            </EmbeddedResource>
            <EmbeddedResource MyAssemblyResource="true" />
            <AdditionalFiles Include="@(EmbeddedResource)" />
        </ItemGroup>
    </Target>
</Project>
