{
    "mcpServers": {
        "context7": {
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@upstash/context7-mcp"],
            "env": {
                "CONTEXT7_API_KEY": "\u001b[A\u001b[B"
            }
        },
        "mcp": {
            "type": "http",
            "url": "https://learn.microsoft.com/api/mcp"
        },
        "github-mcp-server": {
            "type": "http",
            "url": "https://api.githubcopilot.com/mcp/",
            "headers": {}
        },
        "nuget": {
            "type": "stdio",
            "command": "nuget-mcp-server",
            "args": []
        }
    }
}
